# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ---- LLM (via LiteLLM) ----
# Provider API keys (set the one your AGENT_MODEL uses):
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
# LiteLLM model string — switch providers by changing this ONE line:
#   anthropic/claude-haiku-4-5 (cheapest Claude) | anthropic/claude-sonnet-4-6 | anthropic/claude-opus-4-8
#   gemini/gemini-2.5-flash-lite (very cheap) | gpt-4o-mini
AGENT_MODEL=anthropic/claude-haiku-4-5

# ---- Cronometer MCP (unofficial mobile REST API) ----
CRONOMETER_USERNAME=
CRONOMETER_PASSWORD=

# ---- Google Health API v4 (Fitbit/Pixel, OAuth 2.0) ----
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REDIRECT_URI=http://127.0.0.1:3000/callback

# ---- ResMed MyAir (unofficial) ----
MYAIR_USERNAME=
MYAIR_PASSWORD=
MYAIR_REGION=US  # US (Cognito) or EU (legacy)

# ---- Telegram bot (Phase 1 chat surface) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=  # comma-separated Telegram user IDs allowed to chat

# ---- Database ----
# Local runs (bot/MCP in terminals) use SQLite by default. docker-compose overrides
# DATABASE_URL to point the backend service at the Postgres container.
DATABASE_URL=sqlite+aiosqlite:///./nutrimind.db
# Postgres (used by docker-compose):
POSTGRES_USER=nutrimind
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nutrimind

# ---- Backend / Web app ----
API_BEARER_TOKEN=  # owner (admin) password for the web app + API
LOG_LEVEL=INFO

# ---- Web auth (Google sign-in + admin approval) ----
ADMIN_EMAIL=            # your Google email — auto-approved as admin
GOOGLE_CLIENT_ID=       # OAuth 2.0 Web client ID (from Google Cloud console)
SESSION_SECRET=         # long random string used to sign login sessions (set in prod!)
